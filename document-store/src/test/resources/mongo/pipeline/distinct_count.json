[
  {
    "$match": {
      "class": {
        "$lte": 10
      }
    }
  },
  {
    "$group": {
      "_id": {
        "class": "$class"
      },
      "section_count": {
        "$addToSet": "$section"
      }
    }
  },
  {
    "$project": {
      "section_count": {
        "$size": {
          "$ifNull": [
            "$section_count",
            []
          ]
        }
      }
    }
  }
]
