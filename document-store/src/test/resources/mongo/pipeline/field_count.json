[
  {
    "$group": {
      "_id": null,
      "total": {
        "$sum": {
          "$cond": [
            {
              "$ne": [
                {
                  "$type": "$path"
                },
                "missing"
              ]
            },
            1,
            0
          ]
        }
      }
    }
  },
  {
    "$project": {
      "total": "$total"
    }
  }
]
